# ── Gateway settings ──────────────────────────────────
PORT=3000
REDIS_URL=redis://redis:6379
WS_TOKEN_TTL_MINUTES=10
CONVERSATION_TTL_HOURS=24

# ── Provider API keys (set the ones you use) ─────────
# Each tenant can also override these with providerApiKey in tenants.json

OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# OpenAI-compatible providers (Groq, Together, Mistral, DeepSeek, Ollama)
# don't need a key here — set baseUrl + providerApiKey per tenant in tenants.json
